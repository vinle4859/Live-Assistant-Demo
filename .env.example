# Google Cloud project settings.
# Set these in deployment; do not commit real credentials or service account JSON.
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
GEMINI_MODEL=gemini-2.5-flash

# Runtime paths. In Docker, prefer /app/data/knowledge_base.sqlite3 and /app/output.
VOICE_LOOP_DB_PATH=data/knowledge_base.sqlite3
VOICE_LOOP_OUTPUT_DIR=output

# Provider timing. The LLM value is a ceiling; live direct answers clamp to 8s normally and 10s for current/search prompts.
VOICE_LOOP_PROVIDER_TIMEOUT_SECONDS=8.0
VOICE_LOOP_LLM_TIMEOUT_SECONDS=15.0
VOICE_LOOP_LLM_ENABLE_GOOGLE_SEARCH=true
VOICE_LOOP_LOG_LEVEL=INFO

# Live assistant tuning.
VOICE_LOOP_WAKE_WORD=hey lemon
VOICE_LOOP_WAKE_ALIASES=hello lemon, hey leman, le minh
VOICE_LOOP_WAKE_ACK_MODE=adaptive
VOICE_LOOP_WAKE_ACK_ADAPTIVE_SPEAK_ON_WAKE=true
VOICE_LOOP_WAKE_ACK_BEEP_FREQUENCY=880
VOICE_LOOP_WAKE_ACK_BEEP_DURATION_MS=120
VOICE_LOOP_WAKE_ACK_PROMPT_TEXT_EN=Yes?
VOICE_LOOP_WAKE_ACK_PROMPT_TEXT_VI=Tôi có thể giúp gì cho bạn?
VOICE_LOOP_REQUEST_READY_CUE_MODE=speech
VOICE_LOOP_REQUEST_READY_FIRST_TEXT_EN=Go ahead.
VOICE_LOOP_REQUEST_READY_FIRST_TEXT_VI=Bạn hỏi đi.
VOICE_LOOP_REQUEST_READY_TEXTS_EN=Go ahead.
VOICE_LOOP_REQUEST_READY_TEXTS_VI=Bạn hỏi đi.
VOICE_LOOP_REQUEST_READY_CACHE=true
VOICE_LOOP_THINKING_CUE_ENABLED=true
VOICE_LOOP_THINKING_CUE_DELAY_SECONDS=1.2
VOICE_LOOP_THINKING_TEXTS_EN=One moment.
VOICE_LOOP_THINKING_TEXTS_VI=Chờ tôi một chút.

# Capture and streaming STT.
VOICE_LOOP_WAKE_WINDOW_SECONDS=2.5
VOICE_LOOP_UTTERANCE_SECONDS=15.0
VOICE_LOOP_UTTERANCE_MIN_RMS=30.0
VOICE_LOOP_UTTERANCE_MIN_PEAK=250.0
VOICE_LOOP_REQUEST_POST_TTS_GUARD_SECONDS=0.15
VOICE_LOOP_MIN_TRANSCRIPT_CHARACTERS=4
VOICE_LOOP_ENABLE_STREAMING_STT=true
VOICE_LOOP_STREAMING_CHUNK_DURATION_MS=100
VOICE_LOOP_STREAMING_SPEECH_START_TIMEOUT_SECONDS=8.0
VOICE_LOOP_STREAMING_SPEECH_END_TIMEOUT_SECONDS=1.8
VOICE_LOOP_STREAMING_LOCAL_SPEECH_END_MS=2000
VOICE_LOOP_STREAMING_MAX_ACTIVE_SECONDS=10.0
VOICE_LOOP_STREAMING_NO_PROGRESS_SECONDS=4.5
VOICE_LOOP_STREAMING_WEAK_PROGRESS_SECONDS=6.0
VOICE_LOOP_STREAMING_WEAK_PROGRESS_MIN_TOKENS=3
VOICE_LOOP_PREROLL_ENABLED=true
VOICE_LOOP_PREROLL_MS=750
VOICE_LOOP_STARTUP_CALIBRATION_ENABLED=true
VOICE_LOOP_STARTUP_CALIBRATION_SECONDS=2.0
VOICE_LOOP_SAMPLE_RATE=44100
VOICE_LOOP_INPUT_DEVICE_INDEX=

# STT / TTS / LLM providers.
VOICE_LOOP_STT_PROVIDER=google
VOICE_LOOP_STT_MODEL=
VOICE_LOOP_STT_LOCATION=global
VOICE_LOOP_STT_HINT_PHRASES=hey lemon, lemon, hello lemon, hey leman, le minh, greenwich, greenwich vietnam, greenwich viet nam, greenwich việt nam, đại học greenwich, truong dai hoc greenwich, university of greenwich
VOICE_LOOP_TRANSCRIPT_CHEATS=rmit=greenwich|university,truong,trường,dai hoc,đại học,hoc,học,sinh vien,vietnam,viet nam,việt nam,khac biet,khác biệt,so voi,so với;huflit=greenwich|university,truong,trường,dai hoc,đại học,hoc,học,sinh vien,vietnam,viet nam,việt nam,khac biet,khác biệt,so voi,so với;huflix=greenwich|university,truong,trường,dai hoc,đại học,hoc,học,sinh vien,vietnam,viet nam,việt nam,khac biet,khác biệt,so voi,so với;huflex=greenwich|university,truong,trường,dai hoc,đại học,hoc,học,sinh vien,vietnam,viet nam,việt nam,khac biet,khác biệt,so voi,so với;remix=greenwich|university,truong,trường,dai hoc,đại học,hoc,học,sinh vien,vietnam,viet nam,việt nam,khac biet,khác biệt,so voi,so với,tuition,hoc phi,campus;re mix=greenwich|university,truong,trường,dai hoc,đại học,hoc,học,sinh vien,vietnam,viet nam,việt nam,khac biet,khác biệt,so voi,so với,tuition,hoc phi,campus
VOICE_LOOP_TTS_PROVIDER=google
VOICE_LOOP_LLM_DIRECT_MIN_QUERY_TOKENS=1

# Debug flags. Keep off for normal deployment.
VOICE_LOOP_DEBUG_LLM_TEXT=false
VOICE_LOOP_DEBUG_AUDIO_IO=false
VOICE_LOOP_DEBUG_STT_STREAM=false

# Request session controls.
VOICE_LOOP_REQUEST_MAX_IGNORED_TURNS=5
VOICE_LOOP_REQUEST_MAX_TURNS=0
VOICE_LOOP_REQUEST_IDLE_TIMEOUT_SECONDS=90.0
VOICE_LOOP_REQUEST_MAX_SESSION_SECONDS=600.0
VOICE_LOOP_BARGE_IN_MODE=off
VOICE_LOOP_BARGE_IN_LISTEN_SECONDS=0.7
VOICE_LOOP_BARGE_IN_GRACE_SECONDS=1.2
VOICE_LOOP_BARGE_IN_MIN_RMS=45.0
VOICE_LOOP_BARGE_IN_MIN_PEAK=400.0

# Language policy. CLI --language adaptive|en|vi can override this profile.
VOICE_LOOP_LANGUAGE_MODE=adaptive
VOICE_LOOP_OUTPUT_LANGUAGE_MODE=auto
VOICE_LOOP_OUTPUT_LANGUAGE_FIXED=en
VOICE_LOOP_ENABLE_BILINGUAL_OUTPUT=false
VOICE_LOOP_LANGUAGE_SWITCH_MIN_CONFIDENCE=0.60
VOICE_LOOP_LANGUAGE_SWITCH_STICKY_TURNS=0
VOICE_LOOP_LANGUAGE_OVERRIDE_COMMANDS=true

# Curated Q&A retrieval. Deployment uses the prebuilt SQLite DB.
VOICE_LOOP_QA_RETRIEVAL_MODE=hybrid
VOICE_LOOP_QA_LEXICAL_TOP_K=5
VOICE_LOOP_QA_VECTOR_TOP_K=5
VOICE_LOOP_QA_CONFIDENCE_LOW=0.55
VOICE_LOOP_QA_SEED_AUTO_SYNC=false
VOICE_LOOP_QA_SEED_JSON_PATH=data/qa_seed_vi_en.json
VOICE_LOOP_CONTEXT_LINK_ENABLED=true
VOICE_LOOP_CONTEXT_LINK_MAX_TURN_GAP=2
VOICE_LOOP_CONTEXT_LINK_SHORT_QUERY_MAX_TOKENS=6
VOICE_LOOP_CONTEXT_LINK_MIN_SCORE_DELTA=0.08
